          {
            "weight": 4,
            "remove": {
            },
            "add": {
              "component_groups": [
                "minecraft:tiger_adult",
                "minecraft:tiger_wild"
              ]
            }
          },
          {
            "weight": 4,
            "remove": {
            },
            "add": {
              "component_groups": [
                "minecraft:tiger_adult",
                "minecraft:tiger_wild"
              ]
            }
          },
          {
            "weight": 2,
            "remove": {
            },
            "add": {
              "component_groups": [
                "minecraft:tiger_baby",
                "minecraft:tiger_wild"
              ]

            }
          }
        ]
      },

      "minecraft:entity_born": {
        "remove": {
        },
        "add": {
          "component_groups": [
            "minecraft:tiger_baby",
            "minecraft:tiger_tame"
